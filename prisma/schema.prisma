generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model User {
  id         String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  avatar    String? @db.Text
  role      String   @default("user")
  credits   Int      @default(3)
  createdAt DateTime @default(now())

  readers    Reader[]
  childs     Child[]
  magicLinks MagicLink[]
  donations  Donation[]
  streak     Streak?
  badges     UserBadge[]
  purchases  Purchase[]
}

model Reader {
  id        String   @id @default(cuid())
  name      String
  avatar    String? @db.Text
  relation  String?
  createdAt DateTime @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id])
  recordings Recording[]
}

model Child {
  id        String   @id @default(cuid())
  name      String
  avatar    String? @db.Text
  age       Int?
  color     String   @default("#FF6B6B")
  shareCode String?  @unique
  createdAt DateTime @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id])
  recordings Recording[]
}

model Book {
  id          String   @id @default(cuid())
  title       String
  author      String   @default("")
  cover       String? @db.Text
  coverKey    String? @db.Text
  pageCount   Int      @default(0)
  pages      Json?
  description String? @db.Text
  category    String   @default("infantil")
  createdBy   String?
  createdAt   DateTime @default(now())

  recordings Recording[]
}

model Recording {
  id        String   @id @default(cuid())
  status    String   @default("draft")
  shareCode String?  @unique
  reviewedAt DateTime?
  reviewedBy String?

  readerId String
  reader   Reader @relation(fields: [readerId], references: [id])

  childId  String?
  child    Child? @relation(fields: [childId], references: [id])

  bookId String
  book   Book @relation(fields: [bookId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pages PageRecording[]
}

model PageRecording {
  id         String   @id @default(cuid())
  pageNumber Int
  audioUrl   String? @db.Text
  duration   Float    @default(0)
  createdAt  DateTime @default(now())

  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
}

model MagicLink {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  userId String?
  user   User? @relation(fields: [userId], references: [id])
}

model Donation {
  id          String   @id @default(cuid())
  amount      Float
  method      String   @default("pix")
  donorName   String?
  donorEmail  String?
  message     String?  @db.Text
  status      String   @default("pending")
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  userId String?
  user   User? @relation(fields: [userId], references: [id])
}

model Purchase {
  id         String     @id @default(cuid())
  credits    Int
  amount     Float
  status     String     @default("pending")
  paidAt     DateTime?
  createdAt  DateTime   @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}

model Streak {
  id             String   @id @default(cuid())
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastRecordDate DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String
  criteria    String
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  earnedAt  DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}
